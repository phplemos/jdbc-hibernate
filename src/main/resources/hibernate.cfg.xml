<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
 
        <!-- Configuração da conexão com o MySQL -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/gestao_comercial?useSSL=false&amp;serverTimezone=UTC</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">936558Ma#</property>
 
        <!-- Dialeto: ensina o Hibernate a "falar" a sintaxe SQL específica do MySQL -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>
 
        <!-- Mostra no console o SQL gerado pelo Hibernate (ótimo para aprender e depurar) -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
 
        <!-- "validate" confere se as entidades batem com as tabelas já existentes,
             sem alterar o banco. Como já criamos as tabelas pelo schema.sql, isso é o ideal. -->
        <property name="hibernate.hbm2ddl.auto">validate</property>
 
        <!-- Mapeamento das entidades -->
        <mapping class="model.Cliente"/>
        <mapping class="model.Produto"/>
        <mapping class="model.Estoque"/>
        <mapping class="model.Venda"/>
        <mapping class="model.ItemVenda"/>
 
    </session-factory>
</hibernate-configuration>
 